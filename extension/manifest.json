{
  
  "manifest_version": 3,
  "name": "TabTwin",
  "version": "1.0.0",
  "description": "Real-time browser tab collaboration with AI agent",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/serviceWorker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup-dist/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/cursorOverlay.js",
        "content/annotationOverlay.js",
        "content/actionExecutor.js"
      ]
    }
  ]
}
